{
  "kind": "collectionType",
  "collectionName": "qr_codes",
  "info": {
    "singularName": "qr-code",
    "pluralName": "qr-codes",
    "displayName": "QRCode"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Titre": {
      "type": "text"
    },
    "description": {
      "type": "blocks"
    },
    "commune": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::commune.commune"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "coordonnees": {
      "type": "customField",
      "customField": "plugin::geodata.geojson",
      "options": {
        "info": true
      }
    },
    "site": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::site.site"
    }
  }
}
