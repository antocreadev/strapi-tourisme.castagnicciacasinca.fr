 var typeFromMime = require('./typeFromMime.js');
 
+const EXT_TO_MIME = {
+    gpx: 'application/gpx+xml',
+    kml: 'application/vnd.google-earth.kml+xml',
+    kmz: 'application/vnd.google-earth.kmz',
+    geojson: 'application/geo+json',
+    json: 'application/json',
+    xml: 'application/xml',
+    csv: 'text/csv',
+    txt: 'text/plain',
+};
+
+const getMime = (rawFile)=>{
+    if (rawFile.type) return rawFile.type;
+    const ext = (rawFile.name || '').split('.').pop()?.toLowerCase();
+    return EXT_TO_MIME[ext] || 'application/octet-stream';
+};
+
 const rawFileToAsset = (rawFile, assetSource)=>{
+    const mime = getMime(rawFile);
     return {
         size: rawFile.size / 1000,
         createdAt: new Date(rawFile.lastModified).toISOString(),
         name: rawFile.name,
         source: assetSource,
-        type: typeFromMime.typeFromMime(rawFile.type),
+        type: typeFromMime.typeFromMime(mime),
         url: URL.createObjectURL(rawFile),
         ext: rawFile.name.split('.').pop(),
-        mime: rawFile.type,
+        mime,
         rawFile,
         isLocal: true
     };
